APP_NAME=NovaX
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

# URL du serveur Socket.io (Node.js de Michaël)
# Utilisée dans les vues Blade pour connecter Socket.io côté web
SOCKET_URL=http://localhost:3000

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# ── Base de données MySQL ──────────────────────────────────────
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=novax_db
DB_USERNAME=root
DB_PASSWORD=

# ── Cache & Sessions ──────────────────────────────────────────
BROADCAST_DRIVER=log
CACHE_DRIVER=file
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=120

# ── Mail (optionnel) ──────────────────────────────────────────
MAIL_MAILER=smtp
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="hello@novax.com"
MAIL_FROM_NAME="${APP_NAME}"

# ── Sanctum (tokens API) ──────────────────────────────────────
# Domaines autorisés pour les cookies Sanctum (SPA)
SANCTUM_STATEFUL_DOMAINS=localhost,localhost:3000,127.0.0.1,127.0.0.1:8000
